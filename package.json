{
  "name": "@ghast/memory",
  "version": "0.1.0-alpha.40",
  "description": "Ghast Memory OS: a local-first actionable user-world memory runtime for AI agents.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Trapezohe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trapezohe/ghast-memory-os.git"
  },
  "bugs": {
    "url": "https://github.com/Trapezohe/ghast-memory-os/issues"
  },
  "homepage": "https://github.com/Trapezohe/ghast-memory-os#readme",
  "keywords": [
    "agent-memory",
    "memory-runtime",
    "personal-agent",
    "user-world-memory",
    "sqlite",
    "mcp",
    "memory-benchmark"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "bin": {
    "gmos": "dist/cli/gmos.js",
    "ghast-memory": "dist/cli/gmos.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./store/sqlite": {
      "types": "./dist/store/sqlite/index.d.ts",
      "import": "./dist/store/sqlite/index.js",
      "default": "./dist/store/sqlite/index.js"
    },
    "./gym": {
      "types": "./dist/gym/index.d.ts",
      "import": "./dist/gym/index.js",
      "default": "./dist/gym/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "default": "./dist/mcp/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics/index.d.ts",
      "import": "./dist/diagnostics/index.js",
      "default": "./dist/diagnostics/index.js"
    },
    "./evolution": {
      "types": "./dist/evolution/index.d.ts",
      "import": "./dist/evolution/index.js",
      "default": "./dist/evolution/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.js",
      "default": "./dist/host/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx test/run-tests.ts",
    "test:consumer": "node test/consumer-install-smoke.mjs",
    "examples:quickstart": "node examples/quickstart.mjs",
    "examples:host-adapter": "node examples/host-adapter.mjs",
    "check": "npm run build && npm test && npm run examples:quickstart && npm run examples:host-adapter",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "gym": "node --import tsx src/cli/gmos.ts gym run --db :memory:"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.19"
  }
}
